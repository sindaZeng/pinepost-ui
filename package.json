{
  "name": "pinepost-ui",
  "version": "0.2.0",
  "description": "A playful forest-post themed React component library.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "",
  "homepage": "https://pinepost-ui.local",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "forest",
    "theme"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/pinepost-ui.cjs",
  "module": "./dist/pinepost-ui.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pinepost-ui.js",
      "require": "./dist/pinepost-ui.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0",
    "react-dom": ">=18.2.0 || >=19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
