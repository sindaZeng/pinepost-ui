{
  "name": "pinepost-ui",
  "version": "0.24.0",
  "description": "A playful forest-post themed React component library.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "",
  "homepage": "https://sindazeng.github.io/pinepost-ui/",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sindaZeng/pinepost-ui.git"
  },
  "bugs": {
    "url": "https://github.com/sindaZeng/pinepost-ui/issues"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "forest",
    "theme"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/pinepost-ui.cjs",
  "module": "./dist/pinepost-ui.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pinepost-ui.js",
      "require": "./dist/pinepost-ui.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.ts --base /pinepost-ui/",
    "check": "corepack pnpm verify:public-text && corepack pnpm typecheck && corepack pnpm typecheck:demo && corepack pnpm test && corepack pnpm build && corepack pnpm build:demo && corepack pnpm verify:demo && corepack pnpm verify:demo-architecture && corepack pnpm test:e2e && corepack pnpm pack --dry-run",
    "pack:dry": "corepack pnpm pack --dry-run",
    "prepublishOnly": "corepack pnpm typecheck && corepack pnpm test && corepack pnpm build",
    "release:draft": "node scripts/draft-release-notes.mjs",
    "preview:demo": "vite preview --outDir dist-demo --base /pinepost-ui/",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "typecheck:demo": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "verify:demo": "node scripts/verify-demo-build.mjs",
    "verify:demo-architecture": "node scripts/verify-demo-architecture.mjs",
    "verify:public-text": "node scripts/verify-public-text.mjs",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0",
    "react-dom": ">=18.2.0 || >=19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
